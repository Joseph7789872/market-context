# MarketContext — Environment Variables
# Copy this file to `.env.local` (or `.env`) and fill in real values.
# Never commit actual secrets — this file only holds placeholders.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres, via Prisma)
# -----------------------------------------------------------------------------
# Pooled connection string used by Prisma at runtime (e.g. Supabase's pgbouncer
# port 6543). This is the value wired to `datasource db { url = env("DATABASE_URL") }`
# in prisma/schema.prisma.
DATABASE_URL="postgresql://postgres:your-password@your-project.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct (non-pooled) connection string, used by Prisma for migrations
# (`prisma migrate`/`prisma db push`) against Supabase's pooled connection.
# Not yet referenced in prisma/schema.prisma (no `directUrl` set) — add
# `directUrl = env("DIRECT_URL")` to the datasource block when wiring this up.
DIRECT_URL="postgresql://postgres:your-password@your-project.supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------
# Public Supabase project URL and anon key — safe to expose client-side.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Service role key — server-only, bypasses Row Level Security. Never expose
# this to the client or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# -----------------------------------------------------------------------------
# Admin / Ops
# -----------------------------------------------------------------------------
# Shared secret required (via `x-marketcontext-admin-token` header) to call
# the POST /api/jobs/ingest endpoint. See app/api/jobs/ingest/route.ts.
MARKETCONTEXT_ADMIN_TOKEN="your-value-here"

# -----------------------------------------------------------------------------
# Future data providers — NOT YET WIRED, placeholders for future work
# -----------------------------------------------------------------------------
# lib/providers.ts currently uses deterministic demo providers. Per the
# README's "Production connector notes," these are meant to be replaced with
# SEC EDGAR (free, no key needed), a licensed market news API, a market data
# API, and X/Twitter API access.

# Licensed market news API key (provider not yet chosen).
MARKET_NEWS_API_KEY="your-value-here"

# Market data API key (provider not yet chosen).
MARKET_DATA_API_KEY="your-value-here"

# Official X (Twitter) API bearer token — pay-per-use pricing, no key decided yet.
X_API_BEARER_TOKEN="your-value-here"
